---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';

// 1. Fetch and sort all team text files dynamically
const allMembers = await getCollection('team');
const activeMembers = allMembers
  .filter(member => !member.data.isPast)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// 2. Pre-render the biography text for each member safely
const renderedMembers = await Promise.all(
  activeMembers.map(async (member) => {
    const { Content } = await member.render();
    return { data: member.data, Content };
  })
);
---

<MainLayout 
  title="Team | Molecular Virology Lab"
  description="Meet the investigators, molecular biologists, and research trainees driving discoveries at MJ's Lab."
>
  <Navigation />

  <div class="main-content-wrapper">
    <header class="team-header max-width-wrapper">
      <div class="section-label">LABORATORY ROSTER</div>
      <h1>Investigative Roster</h1>
      <p class="subtitle">The minds parsing complex viral data matrices, structural phenotypes, and molecular topography.</p>
    </header>

    <section class="members-section max-width-wrapper">
      <div class="section-label-mid">ACTIVE RESEARCH COHORT</div>
      
      <div class="members-grid">
        {renderedMembers.map(({ data, Content }) => (
          <div class="member-card">
            <div class="member-badge">{data.role.split(' ')[0]}</div>
            <h3>{data.name}</h3>
            <p class="member-role">{data.role}</p>
            <div class="member-desc">
              <Content />
            </div>
            {data.email && <div class="member-email">✉️ {data.email}</div>}
          </div>
        ))}
      </div>
    </section>
  </div>
</MainLayout>

<style>
  :root {
    --bg-dark: #030712;
    --card-glass: rgba(15, 23, 42, 0.4);
    --border-glass: rgba(255, 255, 255, 0.06);
    --neon-blue: #38bdf8;
    --text-muted: #9ca3af;
  }

  .main-content-wrapper {
    padding-top: 100px;
    background-color: var(--bg-dark);
    color: #f3f4f6;
    font-family: system-ui, sans-serif;
    min-height: 100vh;
    background-image: 
      linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .max-width-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .team-header {
    text-align: center;
    padding: 60px 24px 40px;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--neon-blue);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: #fff;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  .members-section {
    padding: 40px 24px 120px;
  }

  .section-label-mid {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: #64748b;
    margin-bottom: 32px;
    font-weight: 600;
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .member-card {
    background: var(--card-glass);
    border: 1px solid var(--border-glass);
    padding: 32px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .member-card:hover { 
    transform: translateY(-4px); 
    border-color: rgba(56, 189, 248, 0.25); 
  }

  .member-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--neon-blue);
    background: rgba(56, 189, 248, 0.06);
    padding: 4px 8px;
    border-radius: 4px;
    align-self: flex-start;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .member-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px 0;
  }

  .member-role {
    font-size: 0.85rem;
    color: #e5e7eb;
    margin: 0 0 16px 0;
    font-weight: 500;
  }

  .member-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .member-email {
    margin-top: auto;
    font-size: 0.75rem;
    font-family: monospace;
    color: #4b5563;
  }

  .member-card:hover .member-email {
    color: #94a3b8;
  }

  @media (max-width: 1024px) {
    .members-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .members-grid { grid-template-columns: 1fr; }
  }
</style>
